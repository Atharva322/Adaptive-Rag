# API Keys (Required)
OPENAI_API_KEY=sk-your-openai-key-here
TAVILY_API_KEY=tvly-your-tavily-key-here

# Database
SQLITE_DB_PATH=./data/adaptive_rag.db

# Backend URL (for Streamlit frontend)
